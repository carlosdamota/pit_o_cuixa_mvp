# Pit o Cuixa — Environment Configuration
# Copy to .env and fill in values for your environment.
# NEVER commit .env to version control.

# Application environment: dev|prod|test
APP_ENV=prod

# Absolute path to SQLite database file (outside public/ docroot)
DB_PATH=./data/pitocuixa.db

# Base site URL (no trailing slash)
SITE_URL=https://pitocuixa.es

# Session token lifetime in seconds (default: 8 hours = 28800)
SESSION_LIFETIME=28800

# Default locale: es|en
DEFAULT_LOCALE=es
